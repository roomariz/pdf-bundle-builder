# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/

# Virtual environments
.venv/
.venv-win/
.venv-wsl/

# Local app data and private documents
input/
output/
*.pdf

# Safe demo PDFs only
!sample-input/
!sample-input/*.pdf
!docs/demo-output/
!docs/demo-output/sample_bundle.pdf

# Public demo assets
!docs/screenshots/
!docs/screenshots/*.png
!docs/demo.gif